{
  "compilerOptions": {
    "target": "ES2023",

    "strict": true,

    "noUncheckedIndexedAccess": true,

    "exactOptionalPropertyTypes": true,

    "noImplicitOverride": true,

    "noFallthroughCasesInSwitch": true,

    "skipLibCheck": true,

    "esModuleInterop": true,

    "resolveJsonModule": true,

    "isolatedModules": true
  }
}
