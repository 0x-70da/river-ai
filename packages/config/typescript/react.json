{
  "extends": "./base.json",

  "compilerOptions": {
    "jsx": "react-jsx",

    "lib": ["DOM", "DOM.Iterable", "ES2023"],

    "types": ["vite/client"],
    "skipLibCheck": true,
    "allowArbitraryExtensions": true,

    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  }
}
