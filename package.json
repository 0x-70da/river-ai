{
  "name": "river-ai",
  "version": "1.0.0",
  "description": "a simple AI chat application",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    
    "test": "turbo test",
    "test:run": "turbo test:run",
    "test:coverage": "turbo test:coverage",

    "docker:up": "docker compose -f docker-compose.dev.yml up",
    "docker:build": "docker compose -f docker-compose.dev.yml up --build",
    "docker:down": "docker compose -f docker-compose.dev.yml down",

    "docker:logs": "docker compose -f docker-compose.dev.yml logs -f",
    "docker:ps": "docker compose -f docker-compose.dev.yml ps",

    "docker:restart": "pnpm docker:down && pnpm docker:build"
  },
  "keywords": [
    "ai",
    "groq",
    "chatgpt"
  ],
  "author": "0x70da",
  "license": "ISC",
  "packageManager": "pnpm@10.30.3",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.2",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "turbo": "^2.10.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.10"
  }
}
